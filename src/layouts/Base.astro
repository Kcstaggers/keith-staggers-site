---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title,
  description = site.description,
  ogType = "website",
  ogImage = "/og-keith-staggers-v2.png",
  ogImageAlt = `${site.name}: AI training, workflow systems, and finished work.`,
} = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.tagline}`;
const requestPath = Astro.url.pathname;
const canonicalPath =
  requestPath === "/" || requestPath.endsWith("/") || /\.[^/]+$/.test(requestPath)
    ? requestPath
    : `${requestPath}/`;
const canonicalUrl = new URL(canonicalPath, site.url).href;
const socialImage = new URL(ogImage, site.url).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      name: site.name,
      alternateName: "Keith Staggers Studio",
      url: `${site.url}/`,
      publisher: { "@id": `${site.url}/#keith` },
      inLanguage: "en-US",
    },
    {
      "@type": "Person",
      "@id": `${site.url}/#keith`,
      name: site.name,
      url: site.url,
      image: `${site.url}/media/keith-photo-9.webp`,
      jobTitle: "AI Creator, Trainer and Workflow Builder",
      description: site.description,
      address: { "@type": "PostalAddress", addressLocality: "Tampa", addressRegion: "FL", addressCountry: "US" },
      sameAs: [
        site.social.linkedin,
        site.social.facebook,
        site.social.instagram,
        site.social.youtube,
        site.social.spotify,
        site.social.appleMusic,
      ].filter(Boolean),
    },
    {
      "@type": "ProfessionalService",
      "@id": `${site.url}/#services`,
      name: "Keith Staggers · AI Systems, Training and Production",
      url: `${site.url}/services/`,
      founder: { "@id": `${site.url}/#keith` },
      areaServed: "Worldwide",
      makesOffer: [
        {
          "@type": "Offer",
          url: `${site.url}/services/done-for-you/`,
          itemOffered: { "@type": "Service", name: "AI Workflow Install Sprint" },
        },
        {
          "@type": "Offer",
          url: `${site.url}/services/coaching/`,
          itemOffered: { "@type": "Service", name: "AI workflow coaching" },
        },
        {
          "@type": "Offer",
          url: `${site.url}/services/training/`,
          itemOffered: { "@type": "Service", name: "Practical AI training" },
        },
        {
          "@type": "Offer",
          url: `${site.url}/services/speaking/`,
          itemOffered: { "@type": "Service", name: "Practical AI speaking" },
        },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content={site.verification.google} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body class="bg-ink text-paper antialiased">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Nav />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <Analytics />

    <script>
      import { track } from "@vercel/analytics";

      const labelFor = (element: Element) =>
        (element.textContent ?? "")
          .replace(/\s+/g, " ")
          .trim()
          .slice(0, 80);

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;

        const pathway = event.target.closest<HTMLElement>("[data-path-tab]");
        if (pathway) {
          track("Pathway Selected", {
            pathway: pathway.dataset.pathTab,
            page: window.location.pathname,
          });
          return;
        }

        const media = event.target.closest<HTMLElement>("[data-open-media]");
        if (media) {
          track("Media Opened", {
            title: media.dataset.mediaTitle,
            format: media.dataset.mediaType,
            page: window.location.pathname,
          });
          return;
        }

        const link = event.target.closest<HTMLAnchorElement>("a[href]");
        if (!link) return;

        const href = link.getAttribute("href") ?? "";
        const source = labelFor(link);
        const page = window.location.pathname;

        if (link.dataset.productPurchase) {
          track("Product Checkout Intent", {
            product: link.dataset.productPurchase,
            source,
            page,
          });
        } else if (href === "/workflow-readiness/") {
          track("Readiness Started", { source, page });
        } else if (href === "/project-fit/") {
          track("Qualification Started", { source, page });
        } else if (href === "/ai-workflow-guide.pdf") {
          track("Guide Download", { source, page });
        } else if (href.includes("facebook.com")) {
          track("Facebook Follow Intent", { source, page });
        } else if (/^\/services\/[^/]+\/$/.test(href)) {
          track("Service Interest", {
            service: href.split("/")[2],
            source,
            page,
          });
        } else if (/^\/notes\/[^/]+\/$/.test(href)) {
          track("Studio Note Opened", {
            note: href.split("/")[2],
            source,
            page,
          });
        }
      });

      document.addEventListener("submit", (event) => {
        if (!(event.target instanceof HTMLFormElement)) return;
        if (event.target.matches("[data-project-fit-form]")) {
          track("Qualification Send Attempt", { page: window.location.pathname });
        } else if (event.target.matches("[data-readiness-form]")) {
          track("Readiness Completed", { page: window.location.pathname });
        } else if (event.target.matches("[data-readiness-followup]")) {
          track("Readiness Follow-up Attempt", { page: window.location.pathname });
        }
      });
    </script>

    <script>
      // Subtle scroll-reveal on each section's direct children. Skipped
      // entirely for users who prefer reduced motion.
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const targets = document.querySelectorAll<HTMLElement>("main section > *");
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
        );
        targets.forEach((el) => {
          // Don't hide anything already in the first viewport on load.
          if (el.getBoundingClientRect().top < window.innerHeight * 0.9) return;
          el.classList.add("reveal");
          io.observe(el);
        });
      }
    </script>

  </body>
</html>
