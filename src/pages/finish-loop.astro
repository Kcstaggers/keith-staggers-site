---
import Base from "../layouts/Base.astro";
import { finishLoop } from "../data/products";
import { site } from "../data/site";
import { getBookingHref, getCalAttrs } from "../utils/booking";

const bookingAttrs = getCalAttrs();
const checkoutReady = Boolean(finishLoop.checkoutUrl);
const inclusionPreviews = [
  "/media/finish-loop/field-manual-cover.webp",
  "/media/finish-loop/planner-card-preview.png",
  "/media/finish-loop/shipping-calendar-preview.svg",
  "/media/finish-loop/direction-brief-preview.svg",
  "/media/finish-loop/finish-scorecard-preview.svg",
];
const inclusionAlt = [
  "The Finish Loop field manual cover",
  "The Finish Loop offline interactive planner preview",
  "The 30-day shipping calendar release rhythm",
  "A reusable direction brief with outcome, success, constraints, and hard stop fields",
  "The editable Finish scorecard with production readiness gates",
];
const productJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "@id": `${site.url}/finish-loop/#product`,
      name: finishLoop.name,
      description: finishLoop.description,
      url: `${site.url}/finish-loop/`,
      image: `${site.url}/media/finish-loop/field-manual-cover.webp`,
      brand: { "@type": "Brand", name: site.name },
      offers: {
        "@type": "Offer",
        price: String(finishLoop.price),
        priceCurrency: finishLoop.currency,
        availability: "https://schema.org/InStock",
        url: `${site.url}/finish-loop/`,
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${site.url}/finish-loop/#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${site.url}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: finishLoop.name,
          item: `${site.url}/finish-loop/`,
        },
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${site.url}/finish-loop/#faq`,
      mainEntity: finishLoop.faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
  ],
};
---

<Base
  title="The Finish Loop · Creator Operating System"
  description={finishLoop.description}
  ogImage="/media/finish-loop/finish-loop-og.png"
  ogImageAlt="The Finish Loop: Finish the work. Ship the thing. $49 manual, planner, and calendar."
>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />

  <nav class="mx-auto max-w-[1600px] px-5 pt-8 font-mono text-[11px] tracking-[0.18em] uppercase text-paper-faint sm:px-8 lg:px-12 xl:px-16" aria-label="Breadcrumb">
    <a href="/" class="transition-colors hover:text-paper">Home</a>
    <span class="mx-2 text-rule" aria-hidden="true">/</span>
    <span class="text-cobalt-text" aria-current="page">The Finish Loop</span>
  </nav>

  <section class="border-b border-paper bg-ink" aria-labelledby="finish-loop-title">
    <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(0,1fr)] lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)]">
      <div class="flex min-h-[670px] min-w-0 flex-col justify-between border-paper px-5 py-12 sm:px-8 lg:border-r lg:px-12 lg:py-16 xl:px-16">
        <div>
          <p class="eyebrow !text-cobalt-text">The Finish Loop</p>
          <h1 id="finish-loop-title" class="serif mt-6 max-w-[720px] text-[clamp(3rem,12.5vw,8.8rem)] leading-[0.83] tracking-[-0.065em] sm:text-[clamp(4rem,8vw,8.8rem)]">
            Finish the work.<br />Ship the thing<span class="text-signal">.</span>
          </h1>
          <p class="serif mt-9 max-w-xl text-xl leading-snug sm:text-2xl">{finishLoop.description}</p>
        </div>

        <div class="mt-12 border-t border-paper pt-7">
          <div class="flex flex-wrap items-end gap-x-5 gap-y-2">
            <span class="serif text-6xl tracking-[-0.05em]">${finishLoop.price}</span>
            <span class="eyebrow pb-2 !text-paper-dim">One-time access · no subscription</span>
          </div>
          {checkoutReady ? (
            <a
              href={finishLoop.checkoutUrl}
              data-product-purchase={finishLoop.slug}
              class="mt-5 inline-flex min-h-13 items-center justify-center bg-cobalt px-7 py-3 font-bold text-white transition-colors hover:bg-cobalt-dim"
            >
              Get The Finish Loop →
            </a>
          ) : (
            <span class="mt-5 inline-flex min-h-13 items-center justify-center border border-paper-faint px-7 py-3 font-bold text-paper-dim" aria-disabled="true">
              Secure checkout being connected
            </span>
          )}
          <p class="mt-3 text-sm text-paper-dim">Immediate digital delivery after checkout.</p>
        </div>
      </div>

      <div class="relative min-h-[560px] min-w-0 overflow-hidden bg-paper">
        <img
          src="/media/keith-photo-5.webp"
          alt="Keith Staggers in a navy suit reviewing a project on his phone"
          width="1080"
          height="1080"
          class="h-full min-h-[560px] w-full object-cover object-center"
        />
        <div class="absolute bottom-5 left-5 w-[42%] max-w-[330px] border border-rule bg-paper p-3 shadow-xl sm:bottom-8 sm:left-8 sm:p-4">
          <img
            src="/media/finish-loop/field-manual-cover.webp"
            alt="The Finish Loop field manual cover"
            width="900"
            height="1165"
            class="w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-rule" aria-label="Proof">
    <div class="mx-auto grid max-w-[1600px] grid-cols-3 divide-x divide-rule">
      {finishLoop.proof.map((item) => (
        <div class="px-3 py-9 text-center sm:px-8 sm:py-12">
          <p class="serif text-[clamp(2.4rem,6vw,5.5rem)] leading-none tracking-[-0.05em]">{item.value}</p>
          <p class="mt-2 text-xs text-paper-dim sm:text-base">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-b border-paper bg-paper text-ink" aria-labelledby="loop-heading">
    <div class="mx-auto max-w-[1600px] px-5 py-16 sm:px-8 lg:px-12 lg:py-24 xl:px-16">
      <div class="grid grid-cols-[minmax(0,1fr)] gap-10 lg:grid-cols-[minmax(0,0.62fr)_minmax(0,1.38fr)] lg:gap-16">
        <div>
          <p class="eyebrow !text-cobalt-text">The six-step loop</p>
          <h2 id="loop-heading" class="serif mt-5 max-w-lg text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">
            A repeatable system. Built for solo creators.
          </h2>
          <p class="mt-7 max-w-md text-lg leading-relaxed text-ink/70">{finishLoop.promise}</p>
        </div>

        <ol class="grid grid-cols-[minmax(0,1fr)] border-l border-t border-ink/30 sm:grid-cols-2 xl:grid-cols-3">
          {finishLoop.steps.map((step) => (
            <li class="min-h-56 border-b border-r border-ink/30 p-6">
              <p class="serif text-6xl leading-none tracking-[-0.05em]">{step.num}</p>
              <h3 class:list={["serif mt-4 text-3xl", step.name === "Release" && "text-signal"]}>{step.name}</h3>
              <p class="mt-4 leading-relaxed text-ink/70">{step.detail}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section id="included" class="border-b border-rule scroll-mt-20" aria-labelledby="includes-heading">
    <div class="mx-auto max-w-[1600px] px-5 py-16 sm:px-8 lg:px-12 lg:py-24 xl:px-16">
      <div class="grid grid-cols-[minmax(0,1fr)] gap-12 lg:grid-cols-[minmax(0,0.55fr)_minmax(0,1.45fr)] lg:gap-16">
        <div>
          <p class="eyebrow !text-cobalt-text">What you get</p>
          <h2 id="includes-heading" class="serif mt-5 max-w-md text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">
            Everything you need to finish and ship.
          </h2>
        </div>
        <div class="grid min-w-0 grid-cols-[minmax(0,1fr)] border-l border-t border-rule sm:grid-cols-2 xl:grid-cols-5">
          {finishLoop.includes.map((item, index) => (
            <article class="border-b border-r border-rule p-5">
              <p class="eyebrow !text-cobalt-text">0{index + 1}</p>
              <img
                src={inclusionPreviews[index]}
                alt={inclusionAlt[index]}
                width="900"
                height="1200"
                loading="lazy"
                class="mt-5 aspect-[3/4] w-full border border-rule object-cover"
              />
              <h3 class="serif mt-5 text-2xl leading-tight">{item.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-paper-dim">{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-paper bg-paper text-ink" aria-labelledby="planner-heading">
    <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(0,1fr)] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[minmax(0,0.62fr)_minmax(0,1.38fr)] lg:px-12 lg:py-24 xl:px-16">
      <div class="lg:pr-10">
        <p class="eyebrow !text-cobalt-text">Plan it. Run it. Finish it.</p>
        <h2 id="planner-heading" class="serif mt-5 text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">
          The planner keeps you moving without the noise.
        </h2>
        <p class="mt-7 max-w-md text-lg leading-relaxed text-ink/70">
          Map the work. Track what matters. Export a complete finish plan. The tool runs offline and saves only in your browser.
        </p>
        <ul class="mt-7 space-y-3 border-t border-ink/30 pt-5">
          <li>Six guided decision stages</li>
          <li>Local autosave and progress tracking</li>
          <li>Finish-gate scorecard</li>
          <li>Markdown export and print view</li>
        </ul>
      </div>
      <div class="overflow-hidden border border-ink/40 bg-ink shadow-2xl">
        <img
          src="/media/finish-loop/planner-preview.webp"
          alt="The Finish Loop interactive planner showing a real project plan"
          width="1280"
          height="900"
          class="h-full w-full object-cover object-top"
        />
      </div>
    </div>
  </section>

  <section class="border-b border-rule" aria-labelledby="fit-heading">
    <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(0,1fr)] lg:grid-cols-2">
      <div class="border-rule px-5 py-16 sm:px-8 lg:border-r lg:px-12 lg:py-24 xl:px-16">
        <p class="eyebrow !text-cobalt-text">This is for you if</p>
        <h2 id="fit-heading" class="serif mt-5 text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">You are serious about finishing.</h2>
        <ul class="mt-9 border-t border-rule">
          {finishLoop.fit.map((item) => <li class="border-b border-rule py-5 text-lg">{item}</li>)}
        </ul>
      </div>
      <div class="px-5 py-16 sm:px-8 lg:px-12 lg:py-24 xl:px-16">
        <p class="eyebrow !text-cobalt-text">About Keith Staggers</p>
        <h2 class="serif mt-5 text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">Creator. Director. Builder.</h2>
        <div class="mt-9 grid grid-cols-[minmax(0,1fr)] gap-7 sm:grid-cols-[180px_minmax(0,1fr)]">
          <img src="/media/keith-photo-9.webp" alt="Keith Staggers in a black suit and sunglasses" width="1080" height="1080" class="aspect-square w-full object-cover" />
          <div class="space-y-5 text-lg leading-relaxed text-paper-dim">
            <p>I spent decades making decisions where details mattered, first as a detective, then as a nurse. Now I use the same discipline to build music, books, films, and visual work with AI.</p>
            <p>The Finish Loop is the process underneath that catalog. It exists because generating is easy and closing the loop is rare.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-paper bg-paper text-ink" aria-labelledby="coaching-heading">
    <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(0,1fr)] lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)_minmax(0,0.7fr)]">
      <div class="flex min-h-80 flex-col justify-center bg-ink px-5 py-12 text-paper sm:px-8 lg:px-10" aria-label="The three-part working session">
        <p class="eyebrow !text-paper-dim">The working session</p>
        <ol class="mt-7 border-t border-rule">
          <li class="grid grid-cols-[42px_1fr] gap-3 border-b border-rule py-4">
            <span class="font-mono text-xs font-bold text-cobalt-text">01</span>
            <span>
              <strong class="block text-paper">Bring the project</strong>
              <span class="mt-1 block text-sm leading-relaxed text-paper-dim">One real project, workflow, or decision.</span>
            </span>
          </li>
          <li class="grid grid-cols-[42px_1fr] gap-3 border-b border-rule py-4">
            <span class="font-mono text-xs font-bold text-cobalt-text">02</span>
            <span>
              <strong class="block text-paper">Find the block</strong>
              <span class="mt-1 block text-sm leading-relaxed text-paper-dim">We isolate what is keeping it unfinished.</span>
            </span>
          </li>
          <li class="grid grid-cols-[42px_1fr] gap-3 border-b border-rule py-4">
            <span class="font-mono text-xs font-bold text-signal">03</span>
            <span>
              <strong class="block text-paper">Leave with a plan</strong>
              <span class="mt-1 block text-sm leading-relaxed text-paper-dim">You leave with a concrete next move.</span>
            </span>
          </li>
        </ol>
      </div>
      <div class="border-ink/30 px-5 py-14 sm:px-8 lg:border-r lg:px-12">
        <p class="eyebrow !text-cobalt-text">Work with Keith</p>
        <h2 id="coaching-heading" class="serif mt-5 text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-5xl">60-minute working session</h2>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">Bring the real project. We find the block, apply the system live, and leave with a concrete next move.</p>
      </div>
      <div class="flex flex-col justify-center px-5 py-14 sm:px-8 lg:px-12">
        <p><span class="serif text-6xl tracking-[-0.05em]">$250</span> <span class="eyebrow ml-3 !text-ink/60">One-time session</span></p>
        <a href={getBookingHref()} {...bookingAttrs} class="mt-6 inline-flex min-h-13 items-center justify-center bg-cobalt px-7 py-3 font-bold text-white transition-colors hover:bg-cobalt-dim">
          Start a project inquiry →
        </a>
      </div>
    </div>
  </section>

  <section class="border-b border-rule" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-[1600px] px-5 py-16 sm:px-8 lg:px-12 lg:py-24 xl:px-16">
      <p class="eyebrow !text-cobalt-text">FAQ</p>
      <h2 id="faq-heading" class="serif mt-5 text-[2.5rem] leading-[0.94] tracking-[-0.045em] sm:text-6xl">Before you buy.</h2>
      <p class="mt-6 max-w-2xl text-paper-dim">
        Want the operating idea first? Read <a href="/notes/the-finishing-problem/" class="text-cobalt-text hover:text-paper">why more prompts do not fix a process with no finish line</a>.
      </p>
      <div class="mt-10 grid border-l border-t border-rule md:grid-cols-2 xl:grid-cols-5">
        {finishLoop.faqs.map((item) => (
          <details class="group border-b border-r border-rule p-5" open>
            <summary class="cursor-pointer list-none font-bold">{item.question}</summary>
            <p class="mt-4 text-sm leading-relaxed text-paper-dim">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section id="buy" class="bg-paper text-ink" aria-labelledby="buy-heading">
    <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(0,1fr)] gap-10 px-5 py-20 sm:px-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end lg:px-12 lg:py-28 xl:px-16">
      <div>
        <p class="eyebrow !text-cobalt-text">The Finish Loop</p>
        <h2 id="buy-heading" class="serif mt-5 max-w-4xl text-[clamp(4rem,9vw,8rem)] leading-[0.84] tracking-[-0.055em]">Finish it<span class="text-signal">.</span></h2>
        <p class="mt-7 max-w-2xl text-xl leading-relaxed text-ink/70">Get the manual, planner, calendar, briefs, and scorecard. One payment. Immediate delivery.</p>
      </div>
      <div class="min-w-72 border-t border-ink pt-6 lg:text-right">
        <p class="serif text-6xl tracking-[-0.05em]">${finishLoop.price}</p>
        {checkoutReady ? (
          <a href={finishLoop.checkoutUrl} data-product-purchase={finishLoop.slug} class="mt-5 inline-flex min-h-13 items-center justify-center bg-cobalt px-7 py-3 font-bold text-white transition-colors hover:bg-cobalt-dim">
            Get The Finish Loop →
          </a>
        ) : (
          <span class="mt-5 inline-flex min-h-13 items-center justify-center border border-ink/40 px-7 py-3 font-bold text-ink/60" aria-disabled="true">Secure checkout being connected</span>
        )}
      </div>
    </div>
  </section>
</Base>
