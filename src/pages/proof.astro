---
import Base from "../layouts/Base.astro";
import { books } from "../data/books";
import { site } from "../data/site";

const buildRecord = [
  { value: "21 years", label: "Baltimore detective · 1992 to 2013" },
  { value: "2014 to now", label: "Nurse and nurse leader" },
  { value: "2022 to now", label: "Founder and AI consultant" },
  { value: "50+", label: "Albums released" },
  { value: "800+", label: "Songs released" },
  { value: "1,000+", label: "AI images and films created" },
];
const canonicalUrl = `${site.url}/proof/`;
const proofItems = [
  {
    "@type": "CreativeWork",
    "@id": `${canonicalUrl}#ai-canvas`,
    name: "AI Canvas production shadow",
    description:
      "An owner-run production shadow that proved a durable mock-only execution path with billing, paid providers, and public execution off.",
    creator: { "@id": `${site.url}/#keith` },
  },
  {
    "@type": "CreativeWork",
    "@id": `${canonicalUrl}#gearstat`,
    name: "GearSTAT simulated portfolio build",
    description:
      "An independent nurse-facing simulator built with simulated data. It is not a hospital deployment, client result, or active venture.",
    creator: { "@id": `${site.url}/#keith` },
  },
  ...books.map((book) => ({
    "@type": "Book",
    "@id": `${canonicalUrl}#book-${book.slug}`,
    name: book.title,
    alternateName: book.subtitle,
    description: book.blurb,
    datePublished: "2023",
    author: { "@id": `${site.url}/#keith` },
    url: book.amazonUrl,
    image: `${site.url}/media/book-${book.slug}.webp`,
  })),
];
const proofJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${canonicalUrl}#page`,
      name: "Proof · AI Builds, Books and Finished Work",
      description:
        "Independent AI builds, test records, three healthcare books, and a finished-work record from Keith Staggers.",
      url: canonicalUrl,
      dateModified: "2026-07-23",
      inLanguage: "en-US",
      isPartOf: { "@id": `${site.url}/#website` },
      about: { "@id": `${site.url}/#keith` },
      mainEntity: { "@id": `${canonicalUrl}#work` },
    },
    {
      "@type": "ItemList",
      "@id": `${canonicalUrl}#work`,
      numberOfItems: proofItems.length,
      itemListElement: proofItems.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        item,
      })),
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${site.url}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Proof",
          item: canonicalUrl,
        },
      ],
    },
  ],
};
---

<Base
  title="Proof · AI Builds, Books and Finished Work"
  description="See Keith Staggers' independent AI builds, test records, three healthcare books, and finished-work record. No client outcomes are claimed."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(proofJsonLd)} />
  </Fragment>

  <article class="proof-page">
    <nav class="studio-shell pt-8 font-mono text-[11px] tracking-[0.18em] uppercase text-paper-faint" aria-label="Breadcrumb">
      <a href="/" class="hover:text-paper transition-colors">Home</a>
      <span class="text-rule mx-2" aria-hidden="true">/</span>
      <span class="text-cobalt-text" aria-current="page">Proof</span>
    </nav>

    <header class="studio-shell proof-hero">
      <div>
        <h1 class="studio-display">The work is the <strong>proof</strong><span class="text-signal">.</span></h1>
      </div>
      <p>
        Independent portfolio work: builds, test records, books, and finished releases. No client outcomes are claimed.
      </p>
    </header>

    <section class="proof-canvas" aria-labelledby="proof-canvas-title">
      <div class="studio-shell proof-canvas-grid">
        <div class="proof-video-wrap">
          <a
            data-proof-reel-link
            data-href="https://youtu.be/6WyEbSuM7u4"
            aria-disabled="true"
            class="proof-reel-poster"
            aria-label="AI Canvas production test, scheduled for public release August 2 at 11:00 AM ET"
          >
            <span class="proof-reel-label">Finish Log 002 · AI Canvas demo reel</span>
            <span class="proof-reel-result"><b>4¢</b><i>→</i><b>$0</b></span>
            <span class="proof-reel-caption">The real test · 82 seconds</span>
            <span class="proof-reel-date" data-proof-reel-date aria-hidden="true"><b>08</b><small>02</small></span>
            <span class="proof-reel-play" data-proof-reel-play hidden aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
            </span>
          </a>
          <p class="proof-reel-status" data-proof-reel-status>The public demo publishes August 2 at 11:00 AM ET.</p>
        </div>
        <div class="proof-canvas-copy">
          <p class="studio-kicker">AI Canvas · owner-run production shadow</p>
          <h2 id="proof-canvas-title" class="studio-display">A system that knew the price and still could not <strong>spend the money</strong><span class="text-signal">.</span></h2>
          <p>Keith put a durable production queue behind AI Canvas, then proved the path with one worker, mock mode on, provider keys off, billing off, and public execution off.</p>
          <ul>
            <li><b>2,016</b><span>tests passed before production</span></li>
            <li><b>0 retries</b><span>accepted production canary completed</span></li>
            <li><b>$0.04</b><span>price snapshot quoted</span></li>
            <li><b>$0</b><span>reserved, charged, and provider cost</span></li>
          </ul>
          <a
            data-proof-reel-copy-link
            href="https://youtu.be/6WyEbSuM7u4"
            target="_blank"
            rel="noreferrer"
            hidden
          >Watch the 82-second proof on YouTube ↗</a>
        </div>
      </div>
    </section>

    <section class="studio-shell proof-gearstat" aria-labelledby="proof-gearstat-title">
      <header>
        <p class="studio-kicker">GearSTAT · independent simulated portfolio build</p>
        <h2 id="proof-gearstat-title" class="studio-display">Useful proof.<br /><strong>Hard boundaries</strong><span class="text-signal">.</span></h2>
      </header>
      <div class="proof-case-grid">
        <article>
          <span>01</span>
          <h3>The problem shaped</h3>
          <p>A nurse-facing simulator using simulated data to find hospital equipment and record whether the nurse actually found it.</p>
        </article>
        <article>
          <span>02</span>
          <h3>The build record</h3>
          <p>The recorded July 9 checkpoint reached 206 of 206 tests and 23 of 23 static pages.</p>
        </article>
        <article>
          <span>03</span>
          <h3>The honest limit</h3>
          <p>No PHI, no staff-location display, and no live hospital integration. It is not market proof, a client result, or a hospital deployment.</p>
        </article>
        <article>
          <span>04</span>
          <h3>The current role</h3>
          <p>GearSTAT is a parked portfolio build, not an active venture. The simulator and documentation show workflow thinking without overstating provenance.</p>
        </article>
      </div>
    </section>

    <section class="proof-books" aria-labelledby="proof-books-title">
      <div class="studio-shell">
        <header class="proof-books-head">
          <h2 id="proof-books-title" class="studio-display">Three healthcare books.<br /><strong>Published in 2023</strong><span class="text-signal">.</span></h2>
          <p>Leadership, burnout, and the reality of med-surg, written from inside the work.</p>
        </header>
        <div class="proof-book-list">
          {books.map((book) => (
            <a href={book.amazonUrl} target="_blank" rel="noreferrer" class="proof-book">
              <img src={`/media/book-${book.slug}.webp`} alt={`${book.title} book cover`} width="600" height="900" loading="lazy" decoding="async" />
              <span><b>{book.title}</b><small>{book.subtitle}</small></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="studio-shell proof-record" aria-labelledby="proof-record-title">
      <header>
        <h2 id="proof-record-title" class="studio-display">The build <strong>record</strong><span class="text-signal">.</span></h2>
        <p>Three careers, one standard: observe carefully, build the useful thing, verify it, and finish.</p>
      </header>
      <dl>
        {buildRecord.map((item) => (
          <div>
            <dt>{item.value}</dt>
            <dd>{item.label}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="proof-boundary">
      <div class="studio-shell proof-boundary-grid">
        <div>
          <p class="studio-kicker">Portfolio boundary</p>
          <h2 class="studio-display">Independent work only<span class="text-signal">.</span></h2>
        </div>
        <p>Employer projects, employer data, patient information, and internal healthcare workflows are excluded from this portfolio.</p>
      </div>
    </section>

    <section class="studio-shell proof-close">
      <div>
        <h2 class="studio-display">Bring me the workflow<span class="text-signal">.</span></h2>
        <p>If you need practical training, a tested workflow, or help finishing the right build, start with the fit questions.</p>
      </div>
      <div>
        <a href="/project-fit/" class="studio-button studio-button--primary">Start with fit questions</a>
        <a href="/services/" class="studio-button studio-button--secondary">Explore services</a>
      </div>
    </section>
  </article>

  <script>
    const proofReelStatus = document.querySelector<HTMLElement>("[data-proof-reel-status]");
    const proofReelLink = document.querySelector<HTMLAnchorElement>("[data-proof-reel-link]");
    const proofReelCopyLink = document.querySelector<HTMLAnchorElement>("[data-proof-reel-copy-link]");
    const proofReelDate = document.querySelector<HTMLElement>("[data-proof-reel-date]");
    const proofReelPlay = document.querySelector<HTMLElement>("[data-proof-reel-play]");
    const proofReelReleaseAt = Date.parse("2026-08-02T11:00:00-04:00");

    const unlockProofReel = () => {
      if (!proofReelLink) return;
      const href = proofReelLink.dataset.href;
      if (href) {
        proofReelLink.href = href;
        proofReelLink.target = "_blank";
        proofReelLink.rel = "noreferrer";
        proofReelLink.removeAttribute("aria-disabled");
        proofReelLink.setAttribute("aria-label", "Watch the AI Canvas production test on YouTube");
        proofReelDate?.setAttribute("hidden", "");
        proofReelPlay?.removeAttribute("hidden");
        proofReelCopyLink?.removeAttribute("hidden");
        if (proofReelStatus) proofReelStatus.textContent = "The public demo is available on YouTube.";
      }
    };

    const proofReelUnlockDelay = proofReelReleaseAt - Date.now();
    if (proofReelUnlockDelay <= 0) {
      unlockProofReel();
    } else {
      window.setTimeout(unlockProofReel, proofReelUnlockDelay);
    }
  </script>
</Base>
