---
import Base from "../layouts/Base.astro";
import { formConfigured, formEndpoint } from "../data/forms";
---

<Base
  title="Project fit"
  description="Answer a few direct questions before requesting time with Keith Staggers. Keith reviews every inquiry before sharing a private booking link."
>
  <section class="project-fit" aria-labelledby="project-fit-title">
    <div class="studio-shell project-fit-shell">
      <header class="project-fit-head">
        <div>
          <p class="studio-kicker">Before the calendar</p>
          <h1 id="project-fit-title" class="studio-display">
            Show me the<br /><strong>real problem</strong><span class="text-signal">.</span>
          </h1>
        </div>
        <div class="project-fit-intro">
          <p>I review every inquiry before sharing a private booking link. A clear workflow, owner, input, finish line, and human check save both of us a meeting that should have been an email.</p>
          <a href="/workflow-readiness/">Not sure the job is ready? Take the free readiness check →</a>
        </div>
      </header>

      <ol class="project-fit-steps" aria-label="How the project fit process works">
        <li><span>01</span><b>Answer</b><p>Name the outcome, timeline, and right level of investment.</p></li>
        <li><span>02</span><b>Send securely</b><p>Your inquiry goes to Keith's private inbox without publishing an email address.</p></li>
        <li><span>03</span><b>Then we talk</b><p>If it fits, I reply with the private calendar link and the right next step.</p></li>
      </ol>

      <div class="project-fit-grid">
        <aside class="project-fit-aside">
          <p class="studio-kicker">A good inquiry includes</p>
          <ul>
            <li>A specific result, not “help with AI.”</li>
            <li>A real owner or decision-maker.</li>
            <li>A timeline tied to actual work.</li>
            <li>A budget or hiring conversation that matches the ask.</li>
          </ul>
          <p class="project-fit-privacy">Your details are used only to evaluate and reply to this inquiry. Do not include protected health information, confidential employer or client data, passwords, or API keys.</p>
        </aside>

        <form
          class="project-fit-form"
          data-project-fit-form
          data-form-configured={String(formConfigured)}
          action={formEndpoint || undefined}
          method="post"
          accept-charset="UTF-8"
        >
          <input type="hidden" name="subject" value="[KS Project Fit] {{ email }}" />
          <input type="hidden" name="form_type" value="Project Fit" />
          <input type="hidden" name="inquiry_marker" value="ks-project-fit-v1" />
          <input type="hidden" name="source_page" value="/project-fit/" />

          <div class="form-honeypot" aria-hidden="true">
            <label for="fit-company-site">Leave this field empty</label>
            <input id="fit-company-site" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-name">Your name</label>
            <input id="fit-name" name="name" type="text" autocomplete="name" maxlength="120" required />
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-email">Your email</label>
            <input id="fit-email" name="email" type="email" autocomplete="email" maxlength="254" required />
          </div>

          <div class="fit-field">
            <label for="fit-role">Organization and your role</label>
            <input id="fit-role" name="role" type="text" autocomplete="organization-title" maxlength="180" placeholder="Company, team, or independent project" required />
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-need">What conversation do you need?</label>
            <select id="fit-need" name="need" required>
              <option value="">Choose one</option>
              <option>AI Workflow Install Sprint</option>
              <option>AI Jumpstart one-to-one session</option>
              <option>Team training or workshop</option>
              <option>Speaking or event</option>
              <option>Employment or recruiter conversation</option>
              <option>Not sure yet</option>
            </select>
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-timeline">When does this need to move?</label>
            <select id="fit-timeline" name="timeline" required>
              <option value="">Choose one</option>
              <option>Within 30 days</option>
              <option>Within 1 to 3 months</option>
              <option>Within 3 to 6 months</option>
              <option>Exploring with no date yet</option>
            </select>
          </div>

          <div class="fit-field">
            <label for="fit-outcome">What must be true when the work is finished?</label>
            <textarea id="fit-outcome" name="outcome" rows="5" minlength="40" maxlength="2000" placeholder="Describe the result, who will use it, and what finished means." required></textarea>
          </div>

          <div class="fit-field">
            <label for="fit-input">What starts the workflow, and what material goes in?</label>
            <textarea id="fit-input" name="input" rows="3" minlength="20" maxlength="1200" placeholder="Name the trigger, source material, and where it currently lives." required></textarea>
          </div>

          <div class="fit-field">
            <label for="fit-approval">Who checks or approves the result before it is used or sent?</label>
            <input id="fit-approval" name="approval" type="text" minlength="5" maxlength="300" placeholder="Name the role, even if that person is you." required />
          </div>

          <div class="fit-field">
            <label for="fit-tried">What have you already tried, built, or decided?</label>
            <textarea id="fit-tried" name="tried" rows="4" minlength="20" maxlength="1600" placeholder="Tools, drafts, internal attempts, approvals, or blockers." required></textarea>
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-investment">Which level fits the conversation?</label>
            <select id="fit-investment" name="investment" required>
              <option value="">Choose one</option>
              <option>Employment or recruiter discussion</option>
              <option>$250 working session</option>
              <option>$2,500+ Workflow Install Sprint</option>
              <option>$3,500+ training or speaking</option>
              <option>$5,000+ expanded workflow or production build</option>
              <option>I need guidance before choosing</option>
            </select>
          </div>

          <div class="fit-field fit-field--half">
            <label for="fit-link">Website or profile</label>
            <input id="fit-link" name="link" type="url" inputmode="url" maxlength="500" placeholder="https://" />
          </div>

          <label class="fit-confirm" for="fit-confirm">
            <input id="fit-confirm" name="confidentiality_confirmed" type="checkbox" value="Confirmed" required />
            <span>I confirm this contains no protected, confidential, or credential information.</span>
          </label>

          <label class="fit-confirm" for="fit-consent">
            <input id="fit-consent" name="contact_consent" type="checkbox" value="Consented" required />
            <span>I consent to Keith using the contact details above to evaluate and reply to this inquiry.</span>
          </label>

          <p
            class="form-status"
            data-fit-status
            data-state={formConfigured ? "ready" : "error"}
            aria-live="polite"
          >
            {formConfigured
              ? "Your inquiry will be sent through Formspree to Keith's private inbox."
              : "Inquiry delivery is not configured yet. The form will not send."}
          </p>

          <button class="studio-button studio-button--primary fit-submit" type="submit" disabled={!formConfigured}>
            <span data-submit-label>Send inquiry</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
          </button>
        </form>
      </div>

      <section class="project-fit-review" data-fit-success hidden tabindex="-1" aria-labelledby="fit-success-title">
        <p class="studio-kicker">Sent securely</p>
        <h2 id="fit-success-title" class="studio-display">Inquiry received<span class="text-signal">.</span></h2>
        <p>Keith will review the fit before offering a private calendar link. If there is a useful next step, the reply will go to the email you provided.</p>
        <div class="project-fit-review-actions">
          <a class="studio-button studio-button--secondary" href="/">Back to the studio</a>
          <a class="studio-button studio-button--secondary" href="/workflow-readiness/">Check another workflow</a>
        </div>
      </section>
    </div>
  </section>
</Base>

<script>
  const fitForm = document.querySelector<HTMLFormElement>("[data-project-fit-form]");
  const fitStatus = document.querySelector<HTMLElement>("[data-fit-status]");
  const fitSuccess = document.querySelector<HTMLElement>("[data-fit-success]");
  const fitSubmit = fitForm?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const fitSubmitLabel = fitForm?.querySelector<HTMLElement>("[data-submit-label]");

  fitForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!fitForm.reportValidity() || !fitStatus || !fitSubmit || !fitSubmitLabel) return;

    const configured = fitForm.dataset.formConfigured === "true";
    const endpoint = fitForm.getAttribute("action");
    if (!configured || !endpoint) {
      fitStatus.dataset.state = "error";
      fitStatus.textContent = "Inquiry delivery is not configured. Nothing was sent.";
      return;
    }

    fitForm.setAttribute("aria-busy", "true");
    fitSubmit.disabled = true;
    fitSubmitLabel.textContent = "Sending...";
    fitStatus.dataset.state = "ready";
    fitStatus.textContent = "Sending your inquiry...";

    try {
      const response = await fetch(endpoint, {
        method: "POST",
        body: new FormData(fitForm),
        headers: { Accept: "application/json" },
      });

      if (!response.ok) throw new Error("Form submission failed");

      fitForm.reset();
      fitForm.hidden = true;
      if (fitSuccess) {
        fitSuccess.hidden = false;
        fitSuccess.focus();
      }
    } catch {
      fitStatus.dataset.state = "error";
      fitStatus.textContent = "That did not send. Check your connection and try again. Your answers are still on this page.";
      fitSubmit.disabled = false;
      fitSubmitLabel.textContent = "Send inquiry";
    } finally {
      fitForm.removeAttribute("aria-busy");
    }
  });
</script>
