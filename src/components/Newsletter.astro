---
---

<section class="px-6 lg:px-12 py-24 lg:py-32 max-w-[1280px] mx-auto">
  <div class="hairline pt-12 grid lg:grid-cols-12 gap-10 lg:gap-16">
    <div class="lg:col-span-7">
      <p class="eyebrow mb-6">The Sunday letter</p>
      <h2 class="serif text-[clamp(36px,5vw,64px)] leading-[1.05] tracking-[-0.01em]">
        One letter, every <span class="accent">Sunday</span>.
      </h2>
      <p class="serif italic text-[20px] lg:text-[22px] text-paper-dim mt-6 max-w-[560px] leading-[1.5]">
        Notes from inside the studio. The tools, the tracks, the books in progress. No fluff. Unsubscribe anytime.
      </p>
    </div>

    <form
      class="lg:col-span-5 self-end w-full"
      action="#"
      method="post"
      data-newsletter-stub
    >
      <label for="newsletter-email" class="sr-only">Email address</label>
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          id="newsletter-email"
          name="email"
          type="email"
          required
          placeholder="you@somewhere.com"
          autocomplete="email"
          class="flex-1 bg-transparent border border-rule rounded-full px-5 py-3.5 text-paper placeholder:text-paper-faint focus:outline-none focus:border-amber transition-colors"
        />
        <button
          type="submit"
          class="font-mono text-[11px] tracking-[0.18em] uppercase px-6 py-3.5 rounded-full border border-amber bg-amber text-ink hover:bg-transparent hover:text-amber transition-colors"
        >
          Subscribe
        </button>
      </div>
      <p class="mt-3 font-mono text-[10.5px] tracking-[0.18em] uppercase text-paper-faint">
        No spam. Unsubscribe anytime.
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('[data-newsletter-stub]') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      if (btn) btn.textContent = 'Wire me up';
      console.log('Newsletter signup submitted (stub).');
    });
  }
</script>
