---
import { site } from "../data/site";
import OrbitalPortrait from "./OrbitalPortrait.astro";

const ctaHref = site.booking.intakePath;
---

<section class="studio-closing" aria-labelledby="studio-closing-title">
  <div class="studio-shell studio-closing-grid">
    <h2 id="studio-closing-title" class="studio-display">Bring me<br />the <strong>problem</strong><span class="text-signal">.</span></h2>
    <div class="studio-closing-portrait"><OrbitalPortrait /></div>
    <div class="studio-closing-action">
      <p>I will tell you whether it needs an install sprint, a workshop, a smaller first move, or nothing at all.</p>
      <a
        href={ctaHref}
        class="studio-button studio-button--primary"
      >
        Start with fit questions
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
      </a>
      <a href={site.social.linkedin} target="_blank" rel="noreferrer" class="studio-email">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18v12H3zM3 7l9 7 9-7" /></svg>
        Message me on LinkedIn
      </a>
    </div>
  </div>
</section>
