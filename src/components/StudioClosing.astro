---
import { site } from "../data/site";
import OrbitalPortrait from "./OrbitalPortrait.astro";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Bring%20me%20the%20idea`;
---

<section class="studio-closing" aria-labelledby="studio-closing-title">
  <div class="studio-shell studio-closing-grid">
    <h2 id="studio-closing-title" class="studio-display">Bring me<br />the <strong>idea</strong><span class="text-signal">.</span></h2>
    <div class="studio-closing-portrait"><OrbitalPortrait /></div>
    <div class="studio-closing-action">
      <p>Available worldwide for production, coaching, training, and speaking.</p>
      <a
        href={ctaHref}
        data-cal-link={site.booking.enabled ? calLink : undefined}
        data-cal-namespace=""
        data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"dark"}' : undefined}
        class="studio-button studio-button--primary"
      >
        Book the session
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
      </a>
      <a href={`mailto:${site.email}`} class="studio-email">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18v12H3zM3 7l9 7 9-7" /></svg>
        {site.email}
      </a>
    </div>
  </div>
</section>
