---
import { site } from "../data/site";
import OrbitalPortrait from "./OrbitalPortrait.astro";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Bring%20me%20the%20idea`;
---

<section class="studio-hero" aria-labelledby="studio-hero-title">
  <div class="studio-shell studio-hero-grid">
    <div class="studio-hero-copy">
      <h1 id="studio-hero-title" class="studio-display studio-hero-title">
        <span>Make the thing</span>
        <span><strong>they cannot</strong></span>
        <span>ignore<span class="text-signal">.</span></span>
      </h1>

      <p class="studio-hero-support">
        AI creative production, coaching, training, and speaking. Built by a detective, nurse leader, and prolific creator.
      </p>

      <div class="studio-actions">
        <a
          href={ctaHref}
          data-cal-link={site.booking.enabled ? calLink : undefined}
          data-cal-namespace=""
          data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"dark"}' : undefined}
          class="studio-button studio-button--primary"
        >
          Bring me the idea
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
        </a>
        <a href="#visuals" class="studio-button studio-button--secondary">
          Enter the work
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
        </a>
      </div>

      <p class="studio-proof-line">
        <span>50+ albums</span><i></i><span>800+ songs</span><i></i><span>3 books</span><i></i><span>1,000+ images &amp; films</span>
      </p>
    </div>

    <div class="studio-hero-portrait">
      <OrbitalPortrait eager />
      <p class="portrait-caption">Turning ambitious ideas into finished work</p>
    </div>
  </div>

  <div class="production-ticker" aria-label="Keith's production loop">
    <div class="production-ticker-track">
      {[0, 1].map(() => (
        <span aria-hidden="true">
          <b>Production loop</b><i>Concept</i><em>→</em><i>Capture</i><em>→</em><i>Compose</i><em>→</em><i>Edit</i><em>→</em><i>Release</i><em>→</em><i>Analyze</i><em>→</em>
        </span>
      ))}
    </div>
  </div>
</section>
