---
import { notes } from "../data/notes";
---

<section id="notes" class="px-6 lg:px-12 py-20 lg:py-28 max-w-[1536px] mx-auto scroll-mt-24">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">
    <header class="lg:col-span-4">
      <p class="eyebrow mb-6">Studio notes · Field tested</p>
      <h2 class="serif text-[clamp(48px,5.5vw,78px)] leading-[0.93] tracking-[-0.035em]">
        What the work taught me<span class="text-signal">.</span>
      </h2>
      <p class="mt-7 text-[17px] leading-[1.65] text-paper-dim max-w-[420px]">
        Clear thinking on AI, creative work, and starting again. No trend reports. No recycled prompts.
      </p>
    </header>

    <div class="lg:col-span-8 border-t border-paper/80">
      {notes.map((note) => (
        <a
          href={`/notes/${note.slug}/`}
          class="note-row group grid sm:grid-cols-[3rem_1fr_auto] gap-4 sm:gap-7 py-7 lg:py-9 border-b border-paper/70"
        >
          <span class="font-mono text-[11px] tracking-[0.14em] text-paper-faint group-hover:text-signal transition-colors">
            {note.number}
          </span>
          <span>
            <span class="block font-mono text-[10px] tracking-[0.15em] uppercase text-amber mb-3">
              {note.category} · {note.readingTime}
            </span>
            <span class="block serif text-[clamp(27px,3vw,42px)] leading-[1.02] tracking-[-0.02em] text-paper group-hover:text-amber transition-colors max-w-[780px]">
              {note.title}
            </span>
            <span class="block mt-4 text-[15px] leading-[1.6] text-paper-dim max-w-[690px]">
              {note.excerpt}
            </span>
          </span>
          <span class="self-center text-amber text-2xl transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
