---
import { albums } from "../data/albums";
import SectionCTA from "./SectionCTA.astro";
const featured = albums.find((a) => a.featured) ?? albums[0];
const rest = albums.filter((a) => a.slug !== featured.slug);
---

<section id="music" class="px-6 lg:px-12 py-24 lg:py-32 max-w-[1280px] mx-auto scroll-mt-24">
  <header class="mb-16">
    <p class="eyebrow mb-6">Pillar · 02 / Music</p>
    <h2 class="serif text-[clamp(40px,5.5vw,72px)] leading-[1] tracking-[-0.01em] mb-6">
      Fifty albums in.
      <span class="text-paper-dim/80 ml-3">eight hundred songs deep</span>
    </h2>
    <p class="serif italic text-[20px] lg:text-[22px] text-paper-dim max-w-[680px] leading-[1.5]">
      Made between night shifts and morning coffee. Still cutting at 3 a.m. A few favorites below. Full catalog lives on every major streaming service and YouTube.
    </p>
  </header>

  <div class="hairline pt-12 grid lg:grid-cols-12 gap-10 lg:gap-12 mb-20">
    <div class="lg:col-span-5">
      <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-amber mb-4">★ Featured</p>
      <h3 class="serif italic text-[48px] leading-none mb-6">{featured.title}</h3>
      <p class="text-paper-dim text-[14px] leading-[1.7] mb-8">
        {featured.featuredBlurb ?? "A favorite. Press play."}
      </p>
      <div class="flex flex-wrap gap-3">
        {featured.appleMusicUrl && (
          <a href={featured.appleMusicUrl} class="font-mono text-[11px] tracking-[0.18em] uppercase px-4 py-2 rounded-full border border-rule text-paper-dim hover:text-paper hover:border-paper-dim transition-colors">Apple Music ↗</a>
        )}
        {featured.amazonMusicUrl && (
          <a href={featured.amazonMusicUrl} class="font-mono text-[11px] tracking-[0.18em] uppercase px-4 py-2 rounded-full border border-rule text-paper-dim hover:text-paper hover:border-paper-dim transition-colors">Amazon ↗</a>
        )}
      </div>
    </div>
    <div class="lg:col-span-7">
      <iframe
        src={`https://open.spotify.com/embed/album/${featured.spotifyId}?utm_source=generator&theme=0`}
        width="100%"
        height="400"
        frameborder="0"
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        class="rounded-md"
        title={`${featured.title} on Spotify`}
      ></iframe>
    </div>
  </div>

  <div class="hairline pt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
    {rest.map((album) => (
      <article class="group">
        <div class="aspect-square bg-[#15110d] border border-rule/80 rounded-sm mb-5 overflow-hidden relative">
          <iframe
            src={`https://open.spotify.com/embed/album/${album.spotifyId}?utm_source=generator&theme=0`}
            width="100%"
            height="100%"
            frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            class="absolute inset-0"
            title={`${album.title} on Spotify`}
          ></iframe>
        </div>
        <h4 class="serif text-[24px] leading-tight">{album.title}</h4>
        <div class="mt-3 flex gap-3 text-[10.5px] font-mono tracking-[0.18em] uppercase text-paper-faint">
          {album.appleMusicUrl && <a href={album.appleMusicUrl} class="hover:text-paper transition-colors">Apple</a>}
          {album.appleMusicUrl && album.amazonMusicUrl && <span class="text-rule">·</span>}
          {album.amazonMusicUrl && <a href={album.amazonMusicUrl} class="hover:text-paper transition-colors">Amazon</a>}
        </div>
      </article>
    ))}
  </div>

  <div class="hairline mt-16 pt-8 flex flex-col items-center gap-4">
    <p class="font-mono text-[10.5px] tracking-[0.22em] uppercase text-paper-faint">
      Available everywhere you stream
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 font-mono text-[10.5px] tracking-[0.18em] uppercase text-paper-dim">
      <span>Spotify</span>
      <span class="text-rule">·</span>
      <span>Apple Music</span>
      <span class="text-rule">·</span>
      <span>Amazon Music</span>
      <span class="text-rule">·</span>
      <span>YouTube</span>
      <span class="text-rule">·</span>
      <span>YouTube Music</span>
      <span class="text-rule">·</span>
      <span>Tidal</span>
      <span class="text-rule">·</span>
      <span>Pandora</span>
      <span class="text-rule">·</span>
      <span>SoundCloud</span>
      <span class="text-rule">·</span>
      <span>Deezer</span>
    </div>
  </div>

  <SectionCTA prompt="Want music, audio, or ghost-produced tracks for your brand?" />
</section>
