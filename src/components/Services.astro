---
import { site } from "../data/site";
import { services } from "../data/services";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const mailtoFallback = `mailto:${site.email}?subject=Work%20with%20me`;
const ctaHref = site.booking.enabled ? `https://cal.com/${calLink}` : mailtoFallback;
---

<section id="services" class="px-6 lg:px-12 py-24 lg:py-32 max-w-[1280px] mx-auto scroll-mt-24">
  <header class="mb-16">
    <p class="eyebrow mb-6">Pillar · 05 / Services</p>
    <h2 class="serif text-[clamp(40px,5.5vw,72px)] leading-[1] tracking-[-0.01em] mb-6">
      Work with me.
      <span class="text-paper-dim/80 ml-3">four ways in</span>
    </h2>
    <p class="serif italic text-[20px] lg:text-[22px] text-paper-dim max-w-[640px] leading-[1.5]">
      Hire the work, hire the brain, hire the room.
    </p>
  </header>

  <div class="hairline pt-12 grid md:grid-cols-2 gap-px bg-rule/60">
    {services.map((s) => (
      <article class="bg-ink p-8 lg:p-10 flex flex-col gap-5">
        <div class="flex items-baseline gap-4">
          <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-amber">{s.num}</span>
          <h3 class="serif text-[28px] lg:text-[32px] leading-none">
            <a href={`/services/${s.slug}/`} class="hover:text-amber transition-colors">{s.title}</a>
          </h3>
        </div>
        <p class="text-paper/85 text-[15px] leading-[1.7] max-w-[480px]">{s.blurb}</p>
        <div class="mt-auto pt-3 flex items-center justify-between gap-4">
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-amber">
            {s.pricing}
          </p>
          <a
            href={`/services/${s.slug}/`}
            class="font-mono text-[10.5px] tracking-[0.18em] uppercase text-paper-faint hover:text-paper transition-colors"
            aria-label={`More about ${s.title}`}
          >
            Details →
          </a>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-16 text-center">
    <a
      href={ctaHref}
      data-cal-link={site.booking.enabled ? calLink : undefined}
      data-cal-namespace=""
      data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"dark"}' : undefined}
      class="inline-flex items-center gap-3 text-[12px] font-mono tracking-[0.18em] uppercase px-10 py-4 rounded-full border border-amber bg-amber text-ink hover:bg-transparent hover:text-amber transition-colors"
    >
      {site.booking.buttonLabel}
      <span aria-hidden="true">→</span>
    </a>
    <p class="mt-6 font-mono text-[10.5px] tracking-[0.18em] uppercase text-paper-faint">
      {site.booking.enabled
        ? "Free intro call · 15 minutes · No-pressure"
        : "Responses within 48 hours · Working worldwide"}
    </p>
  </div>
</section>
