---
import { site } from "../data/site";
import { services } from "../data/services";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Bring%20me%20the%20idea`;
---

<section id="proof" class="px-6 lg:px-12 py-20 lg:py-28 max-w-[1536px] mx-auto scroll-mt-24">
  <span id="services" class="block scroll-mt-24" aria-hidden="true"></span>
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
    <header class="lg:col-span-5">
      <h2 class="serif text-[clamp(52px,6vw,88px)] leading-[0.9] tracking-[-0.035em]">
        The receipts are the résumé<span class="text-signal">.</span>
      </h2>
      <p class="mt-8 text-[20px] leading-[1.55] text-paper-dim max-w-[480px]">
        Three careers. Years of finished work. No theory without evidence.
      </p>
      <p class="mt-6 font-mono text-[10px] sm:text-[11px] tracking-[0.1em] uppercase text-paper-faint leading-[1.8]">
        50+ albums · 800+ songs · 3 books<br />1,000+ images &amp; films · 6K+ followers
      </p>
      <a
        href={ctaHref}
        data-cal-link={site.booking.enabled ? calLink : undefined}
        data-cal-namespace=""
        data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"light"}' : undefined}
        class="group mt-9 w-fit bg-amber text-white px-7 py-4 font-mono text-[12px] tracking-[0.08em] uppercase inline-flex items-center gap-4 hover:bg-amber-dim transition-colors"
      >
        Bring me the idea
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </header>

    <div class="lg:col-span-7 border-t border-paper/80">
      {services.map((service) => (
        <a
          href={`/services/${service.slug}/`}
          class="service-row group grid grid-cols-[auto_1fr_auto] items-start gap-5 sm:gap-8 py-7 border-b border-paper/70"
          aria-label={`${service.title}. ${service.pricing}`}
        >
          <span class="font-mono text-[11px] tracking-[0.14em] text-paper-faint group-hover:text-signal transition-colors">{service.num}</span>
          <span>
            <span class="block serif text-[clamp(27px,3vw,40px)] leading-none text-paper group-hover:text-amber transition-colors">{service.title}</span>
            <span class="block mt-3 text-[15px] leading-[1.55] text-paper-dim max-w-[620px]">{service.blurb}</span>
            <span class="block mt-3 font-mono text-[10px] tracking-[0.12em] uppercase text-paper-faint">{service.pricing}</span>
          </span>
          <svg viewBox="0 0 24 24" class="size-6 text-amber transition-transform group-hover:translate-x-1" aria-hidden="true">
            <path d="M5 12h13M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
