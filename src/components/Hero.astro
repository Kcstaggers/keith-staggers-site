---
import { site } from "../data/site";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : site.booking.intakePath;
---

<section class="px-6 lg:px-12 pt-12 lg:pt-16 pb-10 max-w-[1536px] mx-auto">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-8 items-stretch border-b border-rule">
    <div class="lg:col-span-7 flex flex-col justify-center pb-10 lg:pb-8 lg:pr-8">
      <h1 class="serif text-[clamp(60px,7.8vw,122px)] leading-[0.82] tracking-[-0.04em] max-w-[800px]">
        Make the thing they cannot ignore<span class="text-signal">.</span>
      </h1>

      <p class="mt-8 text-[clamp(19px,1.65vw,25px)] leading-[1.5] text-paper max-w-[680px]">
        I turn ambitious ideas into finished creative work, capable teams, and rooms ready to move.
      </p>

      <a
        href={ctaHref}
        data-cal-link={site.booking.enabled ? calLink : undefined}
        data-cal-namespace=""
        data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"light"}' : undefined}
        class="group mt-8 w-fit bg-cobalt text-white px-7 py-4 font-mono text-[12px] tracking-[0.08em] uppercase inline-flex items-center gap-4 hover:bg-cobalt-dim transition-colors"
      >
        Bring me the idea
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
      </a>

      <div class="mt-7 pt-6 border-t border-paper/70 max-w-[780px]">
        <p class="font-mono text-[10px] sm:text-[11px] tracking-[0.17em] uppercase text-paper-dim flex flex-wrap items-center gap-x-3 gap-y-2">
          <span>Detective</span><span class="text-signal" aria-hidden="true">·</span>
          <span>Nurse leader</span><span class="text-signal" aria-hidden="true">·</span>
          <span>AI-native creator</span>
        </p>
        <p class="mt-4 font-mono text-[10px] sm:text-[12px] tracking-[0.05em] text-paper-dim flex flex-wrap items-center gap-x-3 gap-y-2">
          <span>50+ albums</span><span class="text-signal" aria-hidden="true">·</span>
          <span>800+ songs</span><span class="text-signal" aria-hidden="true">·</span>
          <span>3 books</span><span class="text-signal" aria-hidden="true">·</span>
          <span>1,000+ images &amp; films</span>
        </p>
        <a href={site.social.facebook} target="_blank" rel="noreferrer" class="nav-link mt-5 inline-flex items-center gap-3 text-[16px] text-cobalt hover:text-cobalt-dim transition-colors">
          6K+ follow the work <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <figure class="lg:col-span-5 min-h-[520px] lg:min-h-[650px] relative overflow-hidden bg-paper">
      <img
        src="/media/keith-hero.webp"
        alt="Keith Staggers in a dark suit"
        width="1120"
        height="1400"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
    </figure>
  </div>
</section>
