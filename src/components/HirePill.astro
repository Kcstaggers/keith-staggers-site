---
import { site } from "../data/site";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Work%20with%20me`;

const dotColor =
  site.availability.status === "open"
    ? "bg-amber"
    : site.availability.status === "limited"
      ? "bg-amber/60"
      : "bg-paper-faint";

const pulseClass = site.availability.status === "open" ? "animate-pulse" : "";
---

<aside
  id="hire-pill"
  class="fixed bottom-5 right-5 z-40 max-w-[88vw] hidden"
  aria-label="Hire Keith"
>
  <div class="flex items-center gap-3 bg-[#0e0e0e]/95 backdrop-blur border border-rule/80 rounded-full pl-4 pr-2 py-2 shadow-[0_2px_24px_rgba(0,0,0,0.6)]">
    <a
      href={ctaHref}
      data-cal-link={site.booking.enabled ? calLink : undefined}
      data-cal-namespace=""
      data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"dark"}' : undefined}
      class="flex items-center gap-3 group"
      data-hire-link
    >
      <span class="flex items-center gap-2">
        <span class={`size-2 rounded-full ${dotColor} ${pulseClass} inline-block`} aria-hidden="true"></span>
        <span class="font-mono text-[10.5px] tracking-[0.18em] uppercase text-paper-dim">
          {site.availability.label}
        </span>
      </span>
      <span class="h-4 w-px bg-rule"></span>
      <span class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.18em] uppercase text-amber group-hover:text-paper transition-colors">
        Hire me
        <span aria-hidden="true">→</span>
      </span>
    </a>
    <button
      type="button"
      aria-label="Dismiss"
      data-hire-dismiss
      class="size-7 rounded-full text-paper-faint hover:text-paper hover:bg-rule/60 transition-colors flex items-center justify-center text-[16px] leading-none"
    >×</button>
  </div>
</aside>

<script>
  const KEY = "kss.hirePillDismissed";
  const pill = document.getElementById("hire-pill");
  if (pill) {
    const dismissed = (() => {
      try { return localStorage.getItem(KEY) === "1"; } catch { return false; }
    })();

    if (!dismissed) {
      window.setTimeout(() => pill.classList.remove("hidden"), 1200);
    }

    pill.querySelector("[data-hire-dismiss]")?.addEventListener("click", (e) => {
      e.stopPropagation();
      pill.classList.add("hidden");
      try { localStorage.setItem(KEY, "1"); } catch {}
    });
  }
</script>
