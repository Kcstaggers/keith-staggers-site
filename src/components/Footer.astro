---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="studio-footer">
  <div class="studio-shell">
    <a href="/" class="studio-footer-name">Keith Staggers<span>.</span></a>
    <div class="studio-footer-grid">
      <div>
        <p>AI studio · Training, systems, and finished work</p>
        <p>Available worldwide</p>
      </div>
      <nav aria-label="Footer navigation">
        {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <nav aria-label="Social links">
        <a href={site.social.linkedin} target="_blank" rel="me noreferrer">LinkedIn</a>
        <a href={site.social.facebook} target="_blank" rel="me noreferrer">Facebook</a>
        <a href={site.social.instagram} target="_blank" rel="me noreferrer">Instagram</a>
        <a href={site.social.youtube} target="_blank" rel="me noreferrer">YouTube</a>
        <a href={site.social.spotify} target="_blank" rel="me noreferrer">Spotify</a>
      </nav>
      <div>
        <a href={site.booking.intakePath}>Start a project inquiry</a>
        <p>© {year}</p>
      </div>
    </div>
  </div>
</footer>
