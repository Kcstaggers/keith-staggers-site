---
const eras = [
  {
    years: "1992 - 2013",
    role: "Detective",
    place: "Baltimore Police Department",
  },
  {
    years: "2014 - 2023",
    role: "Registered Nurse",
    place: "Tampa, FL",
  },
  {
    years: "2023 - Now",
    role: "AI-Native Creator",
    place: "Working worldwide",
  },
];
---

<div class="hairline pt-12 grid gap-10 lg:grid-cols-3">
  {eras.map((era, i) => (
    <article class="relative">
      <div class="flex items-center gap-2 font-mono text-[11px] tracking-[0.18em] uppercase text-paper-faint mb-4">
        <span class="size-1.5 rounded-full bg-amber inline-block"></span>
        {era.years}
      </div>
      <h4 class={`serif text-[32px] leading-tight ${i === 2 ? "accent" : ""}`}>
        {era.role}
      </h4>
      <p class="mt-3 text-paper-faint text-[14px] leading-[1.6]">{era.place}</p>
    </article>
  ))}
</div>
