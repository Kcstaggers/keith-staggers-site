---
import { site } from "../data/site";

const ctaHref = "/frontline-nurse-leader/";
---

<header class="studio-nav-wrap">
  <div class="studio-shell studio-nav">
    <a href="/" class="studio-logo">Keith Staggers<span>.</span></a>

    <nav class="studio-nav-links" aria-label="Primary navigation">
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a
      href={ctaHref}
      class="studio-nav-cta"
    >
      Sept 16 cohort
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" /></svg>
    </a>

    <button type="button" class="studio-menu-button" data-studio-menu-button aria-expanded="false" aria-controls="studio-mobile-menu" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="studio-mobile-menu" class="studio-mobile-menu" data-studio-mobile-menu hidden aria-label="Mobile navigation">
    {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href={ctaHref}>See the Sept 16 cohort</a>
  </nav>
</header>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>("[data-studio-menu-button]");
  const mobileMenu = document.querySelector<HTMLElement>("[data-studio-mobile-menu]");

  const closeMenu = () => {
    if (!menuButton || !mobileMenu) return;
    menuButton.setAttribute("aria-expanded", "false");
    menuButton.setAttribute("aria-label", "Open menu");
    mobileMenu.hidden = true;
  };

  menuButton?.addEventListener("click", () => {
    if (!mobileMenu) return;
    const opening = menuButton.getAttribute("aria-expanded") !== "true";
    menuButton.setAttribute("aria-expanded", String(opening));
    menuButton.setAttribute("aria-label", opening ? "Close menu" : "Open menu");
    mobileMenu.hidden = !opening;
  });
  mobileMenu?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });
</script>
