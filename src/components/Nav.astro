---
import { site } from "../data/site";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Work%20with%20me`;
---

<header class="px-6 lg:px-12 py-6 max-w-[1440px] mx-auto flex items-center justify-between gap-6 border-b border-rule/60">
  <a href="/" class="serif text-[22px] tracking-tight leading-none">
    Keith Staggers<span class="accent">.</span>
  </a>
  <nav class="hidden md:flex items-center gap-8 text-[12px] font-mono tracking-[0.08em] text-paper-dim" aria-label="Primary navigation">
    {site.nav.map((item) => (
      <a
        href={item.href}
        target={item.href.startsWith("http") ? "_blank" : undefined}
        rel={item.href.startsWith("http") ? "noreferrer" : undefined}
        class="nav-link hover:text-paper transition-colors"
      >{item.label}</a>
    ))}
  </nav>
  <a
    href={ctaHref}
    data-cal-link={site.booking.enabled ? calLink : undefined}
    data-cal-namespace=""
    data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"light"}' : undefined}
    class="group inline-flex items-center gap-2 bg-amber text-white px-3 sm:px-4 py-3 text-[9px] sm:text-[11px] font-mono tracking-[0.08em] sm:tracking-[0.1em] uppercase whitespace-nowrap hover:bg-amber-dim transition-colors"
  >
    Bring me the idea
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</header>
