---
import { site } from "../data/site";

const calLink = `${site.booking.username}/${site.booking.eventSlug}`;
const ctaHref = site.booking.enabled
  ? `https://cal.com/${calLink}`
  : `mailto:${site.email}?subject=Work%20with%20me`;
---

<header class="px-6 lg:px-12 py-6 flex items-center justify-between gap-6">
  <a href="/" class="serif text-[22px] tracking-tight leading-none">
    Keith Staggers<span class="accent">.</span>
  </a>
  <nav class="hidden md:flex items-center gap-7 text-[12px] font-mono tracking-[0.14em] uppercase text-paper-dim">
    {site.nav.map((item) => (
      <a href={item.href} class="hover:text-paper transition-colors">{item.label}</a>
    ))}
  </nav>
  <a
    href={ctaHref}
    data-cal-link={site.booking.enabled ? calLink : undefined}
    data-cal-namespace=""
    data-cal-config={site.booking.enabled ? '{"layout":"month_view","theme":"dark"}' : undefined}
    class="hidden sm:inline-flex items-center gap-2 text-[11px] font-mono tracking-[0.16em] uppercase px-4 py-2.5 rounded-full border border-amber bg-amber text-ink hover:bg-transparent hover:text-amber transition-colors"
  >
    Hire me
    <span aria-hidden="true">→</span>
  </a>
</header>
