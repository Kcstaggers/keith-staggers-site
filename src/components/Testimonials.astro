---
import { testimonials } from "../data/testimonials";

function initials(name: string): string {
  return name
    .split(/\s+/)
    .map((s) => s[0]?.toUpperCase() ?? "")
    .slice(0, 2)
    .join("");
}
---

{testimonials.length > 0 && (
  <section id="proof" class="px-6 lg:px-12 py-20 lg:py-28 max-w-[1536px] mx-auto scroll-mt-24">
    <header class="mb-16">
      <p class="eyebrow mb-6">Proof from real clients</p>
      <h2 class="serif text-[clamp(40px,5.5vw,72px)] leading-[1] tracking-[-0.01em] mb-6">
        What people say after the work ships<span class="text-signal">.</span>
      </h2>
    </header>

    <div class="hairline pt-12 grid md:grid-cols-3 gap-10 lg:gap-12">
      {testimonials.map((t) => (
        <figure class="flex flex-col gap-6">
          <span aria-hidden="true" class="serif italic text-[48px] text-signal leading-none">&ldquo;</span>
          <blockquote class="serif text-[19px] lg:text-[20px] leading-[1.55] text-paper/95">
            {t.quote}
          </blockquote>
          <figcaption class="mt-auto pt-6 hairline flex items-center gap-3">
            <span class="size-9 rounded-full bg-amber text-white flex items-center justify-center font-mono text-[11px] tracking-[0.08em]">
              {initials(t.name)}
            </span>
            <span class="flex flex-col leading-tight">
              <span class="serif italic text-[15px] text-paper">{t.name}</span>
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-paper-faint">
                {t.role}
              </span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
)}
