---
import { tracks } from "../data/tracks";
---

{tracks.length > 0 && (
  <div
    class="mt-8 max-w-[620px] border border-rule/80 p-4 sm:p-5"
    data-hero-player
    data-tracks={JSON.stringify(tracks)}
  >
    <div class="flex items-center gap-4 sm:gap-5">
      <button
        type="button"
        data-hp-toggle
        aria-label="Play preview"
        class="size-12 shrink-0 rounded-full border border-cobalt text-cobalt flex items-center justify-center hover:bg-cobalt hover:text-ink transition-colors"
      >
        <svg data-hp-icon-play viewBox="0 0 16 16" class="size-4 fill-current ml-0.5" aria-hidden="true"><path d="M3 1.5v13l11-6.5z"/></svg>
        <svg data-hp-icon-pause viewBox="0 0 16 16" class="size-4 fill-current hidden" aria-hidden="true"><path d="M3 2h3.5v12H3zM9.5 2H13v12H9.5z"/></svg>
      </button>
      <div class="min-w-0 flex-1">
        <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-paper-faint mb-1">Now playing · 30-second preview</p>
        <p class="serif text-[17px] text-paper truncate" data-hp-title>{tracks[0].title}</p>
        <div class="mt-3 h-px bg-rule relative overflow-visible">
          <div class="absolute inset-y-0 left-0 bg-cobalt h-px w-0 transition-[width] duration-200 ease-linear" data-hp-bar></div>
        </div>
      </div>
      {tracks.length > 1 && (
        <button
          type="button"
          data-hp-next
          aria-label="Next track"
          class="shrink-0 font-mono text-[10px] tracking-[0.12em] uppercase text-paper-faint hover:text-cobalt transition-colors"
        >
          Next →
        </button>
      )}
    </div>
  </div>
)}

<script>
  const root = document.querySelector<HTMLElement>("[data-hero-player]");
  if (root) {
    const tracks: { title: string; src: string }[] = JSON.parse(root.dataset.tracks || "[]");
    let i = 0;
    const audio = new Audio();
    audio.preload = "none";
    const toggle = root.querySelector<HTMLButtonElement>("[data-hp-toggle]")!;
    const playIcon = root.querySelector<SVGElement>("[data-hp-icon-play]")!;
    const pauseIcon = root.querySelector<SVGElement>("[data-hp-icon-pause]")!;
    const title = root.querySelector<HTMLElement>("[data-hp-title]")!;
    const bar = root.querySelector<HTMLElement>("[data-hp-bar]")!;
    const next = root.querySelector<HTMLButtonElement>("[data-hp-next]");

    const setIcons = (playing: boolean) => {
      playIcon.classList.toggle("hidden", playing);
      pauseIcon.classList.toggle("hidden", !playing);
      toggle.setAttribute("aria-label", playing ? "Pause preview" : "Play preview");
    };

    const load = (n: number, autoplay: boolean) => {
      i = (n + tracks.length) % tracks.length;
      audio.src = tracks[i].src;
      title.textContent = tracks[i].title;
      bar.style.width = "0%";
      if (autoplay) audio.play().catch(() => {});
    };

    toggle.addEventListener("click", () => {
      if (!audio.src) audio.src = tracks[i].src;
      audio.paused ? audio.play().catch(() => {}) : audio.pause();
    });
    next?.addEventListener("click", () => load(i + 1, !audio.paused));
    audio.addEventListener("play", () => setIcons(true));
    audio.addEventListener("pause", () => setIcons(false));
    audio.addEventListener("timeupdate", () => {
      if (audio.duration) bar.style.width = `${(audio.currentTime / audio.duration) * 100}%`;
    });
    // When a clip finishes, stop and cue the next one (do not auto-play on).
    audio.addEventListener("ended", () => load(i + 1, false));

    // Pause the hero when the visitor starts an embedded player (e.g. the
    // Spotify album iframes). Those are cross-origin, so we can't hear their
    // play events directly, but clicking into an iframe blurs the page and
    // makes that iframe the active element. That's our signal to stop.
    window.addEventListener("blur", () => {
      window.setTimeout(() => {
        const el = document.activeElement;
        if (el && el.tagName === "IFRAME" && !audio.paused) audio.pause();
      }, 0);
    });
  }
</script>
